        <mxCell id="b6" parent="s2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="若没找到：用“上次发运结束+1秒附近停车区点”兜底" vertex="1">
          <mxGeometry height="64" width="380" x="25" y="444" as="geometry" />
        </mxCell>
        <mxCell id="b7" parent="s2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="回溯补段：截取起止轨迹→去重排序→构造补偿会话入库" vertex="1">
