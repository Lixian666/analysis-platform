  <diagram id="ingest-card" name="RealTimeDriverTracker_ingestForCard">
    <mxGraphModel dx="1488" dy="836" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="2100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="n1" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="开始：RealTimeDriverTracker" vertex="1">
          <mxGeometry height="52" width="320" x="560" y="40" as="geometry" />
        </mxCell>
        <mxCell id="n2" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="批次为空？" vertex="1">
          <mxGeometry height="90" width="180" x="630" y="120" as="geometry" />
        </mxCell>
        <mxCell id="n2e" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="结束（本批无数据）" vertex="1">
          <mxGeometry height="60" width="200" x="930" y="135" as="geometry" />
        </mxCell>
        <mxCell id="n3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="加载该卡状态（识别窗口/历史轨迹/进行中会话），读取车辆作业类型" vertex="1">
          <mxGeometry height="60" width="580" x="430" y="240" as="geometry" />
        </mxCell>
        <mxCell id="n4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="预处理：补时间戳 → 异常过滤 → 排序去重 → 丢弃已处理旧点" vertex="1">
          <mxGeometry height="60" width="540" x="450" y="325" as="geometry" />
        </mxCell>
        <mxCell id="n5" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="预处理后还有点？" vertex="1">
          <mxGeometry height="90" width="180" x="630" y="410" as="geometry" />
        </mxCell>
        <mxCell id="n5e" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="结束（都被过滤）" vertex="1">
          <mxGeometry height="60" width="200" x="930" y="425" as="geometry" />
        </mxCell>
        <mxCell id="n6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="更新“该卡最新处理时间”" vertex="1">
          <mxGeometry height="50" width="400" x="520" y="530" as="geometry" />
        </mxCell>
        <mxCell id="n7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="循环处理本批每个点" vertex="1">
          <mxGeometry height="44" width="280" x="580" y="605" as="geometry" />
        </mxCell>
        <mxCell id="n8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="推进识别窗口与历史列表；历史超上限则删除最旧点" vertex="1">
          <mxGeometry height="56" width="540" x="450" y="670" as="geometry" />
        </mxCell>
        <mxCell id="n9" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="识别窗口已满？" vertex="1">
          <mxGeometry height="90" width="180" x="630" y="750" as="geometry" />
        </mxCell>
        <mxCell id="n9n" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="否：若有进行中会话，先累计这个点" vertex="1">
          <mxGeometry height="56" width="300" x="920" y="766" as="geometry" />
        </mxCell>
        <mxCell id="n10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="窗口状态分析；按车辆类型选择策略识别当前事件" vertex="1">
          <mxGeometry height="60" width="580" x="430" y="865" as="geometry" />
        </mxCell>
        <mxCell id="n11" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="识别到有效事件？" vertex="1">
          <mxGeometry height="90" width="180" x="630" y="950" as="geometry" />
        </mxCell>
        <mxCell id="n11n" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="否：若有会话则累计点" vertex="1">
          <mxGeometry height="56" width="300" x="920" y="966" as="geometry" />
        </mxCell>
        <mxCell id="n12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="若已有会话：推送一条实时轨迹" vertex="1">
          <mxGeometry height="50" width="400" x="520" y="1070" as="geometry" />
        </mxCell>
        <mxCell id="n13" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="事件分流处理" vertex="1">
          <mxGeometry height="90" width="180" x="630" y="1145" as="geometry" />
        </mxCell>
        <mxCell id="n14" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="本批处理完毕" vertex="1">
          <mxGeometry height="44" width="200" x="620" y="1320" as="geometry" />
        </mxCell>
        <mxCell id="n15" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="结束" vertex="1">
          <mxGeometry height="50" width="130" x="655" y="1385" as="geometry" />
        </mxCell>
        <mxCell id="s1" parent="1" style="swimlane;whiteSpace=wrap;html=1;horizontal=0;fillColor=#f5f5f5;strokeColor=#666666;" value="横向扩展A：事件分流语义" vertex="1">
          <mxGeometry height="520" width="430" x="60" y="1160" as="geometry" />
        </mxCell>
        <mxCell id="a1" parent="s1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="到达上车：必要时先结束上一段，再开启新会话" vertex="1">
          <mxGeometry height="64" width="380" x="25" y="36" as="geometry" />
        </mxCell>
        <mxCell id="a2" parent="s1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="到达下车：结束会话并落库" vertex="1">
          <mxGeometry height="52" width="380" x="25" y="118" as="geometry" />
        </mxCell>
        <mxCell id="a3" parent="s1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="发运上车：当前实现不直接开段" vertex="1">
          <mxGeometry height="52" width="380" x="25" y="188" as="geometry" />
        </mxCell>
        <mxCell id="a4" parent="s1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="发运下车且已有发运会话：直接结束并落库" vertex="1">
          <mxGeometry height="58" width="380" x="25" y="258" as="geometry" />
        </mxCell>
        <mxCell id="a5" parent="s1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="发运下车但无会话：启动回溯补段流程" vertex="1">
          <mxGeometry height="58" width="380" x="25" y="334" as="geometry" />
        </mxCell>
        <mxCell id="s2" parent="1" style="swimlane;whiteSpace=wrap;html=1;horizontal=0;fillColor=#f5f5f5;strokeColor=#666666;" value="横向扩展B：会话闭合与回溯补段" vertex="1">
          <mxGeometry height="700" width="430" x="1030" y="1040" as="geometry" />
        </mxCell>
        <mxCell id="b1" parent="s2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="闭合会话：类型不匹配则忽略结束信号" vertex="1">
          <mxGeometry height="56" width="380" x="25" y="36" as="geometry" />
        </mxCell>
        <mxCell id="b2" parent="s2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="闭合会话：补尾轨迹、整段去重排序、统计作业区信标" vertex="1">
          <mxGeometry height="64" width="380" x="25" y="110" as="geometry" />
        </mxCell>
        <mxCell id="b3" parent="s2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="闭合会话：主表+明细表入库，推送停车区通知" vertex="1">
          <mxGeometry height="60" width="380" x="25" y="192" as="geometry" />
        </mxCell>
        <mxCell id="b4" parent="s2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="回溯补段：历史不足则放弃" vertex="1">
          <mxGeometry height="52" width="380" x="25" y="292" as="geometry" />
        </mxCell>
        <mxCell id="b5" parent="s2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="回溯补段：从下车点向前扫描窗口，查找“发运上车”" vertex="1">
          <mxGeometry height="64" width="380" x="25" y="362" as="geometry" />
